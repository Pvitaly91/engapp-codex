APP_KEY=
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# Host-based site mode. Exact domains and *.wildcards are supported.
# gramlyze.com is production by default; every other host runs in development mode.
SITE_PRODUCTION_DOMAINS=gramlyze.com,www.gramlyze.com,gramlyze.ub
SITE_PRODUCTION_ORIGIN=https://gramlyze.com
SITE_DEVELOPMENT_ORIGIN=http://engapp-codex.loc
# Only these interface languages are public on production hosts.
SITE_PRODUCTION_LOCALES=uk
SITE_DEV_FEATURES=mode-inspector,experimental-ui
SITE_PRODUCTION_RESPONSE_CACHE=true
SITE_PRODUCTION_RESPONSE_CACHE_TTL=300
SITE_PRODUCTION_CACHE_EXCEPT=admin,admin/*,login,logout,test,test/*,api,api/*,health
SITE_MODE_HEADER=true

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SOCKET=
DB_DUMP_PATH=database/dumps/site-database.sql
DB_DUMP_ROWS_PER_INSERT=250

# Beta mode - shows BETA badge and banner
APP_BETA=false

# Coming Soon - enables middleware for routes under development (default: true)
COMING_SOON_ENABLED=true
COMING_SOON_DEV_BYPASS_PREFIXES=/catalog/tests-cards
CATALOG_MAX_TESTS=100

# Admin technical info block on test pages
TEST_TECH_INFO_ENABLED=true

# Your OpenAI API key
CHAT_GPT_API_KEY=sk-your-api-key
CHAT_GPT_LANGUAGE=uk
GEMINI_API_KEY=your-gemini-key

# Deployment GitHub configuration
DEPLOYMENT_GITHUB_OWNER=
DEPLOYMENT_GITHUB_REPO=
DEPLOYMENT_GITHUB_TOKEN=
DEPLOYMENT_GITHUB_USER_AGENT=EngappDeploymentBot/1.0
DEPLOYMENT_RESTORE_BRANCH=main
RESTORE_AUTH_USERNAME=
RESTORE_AUTH_PASSWORD=
