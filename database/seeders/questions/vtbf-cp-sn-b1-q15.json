    "hints": [
        {
            "id": 1862,
            "question_id": 5838,
            "provider": "chatgpt",
            "locale": "uk",
            "hint": "«Unless» означає «якщо не» і вводить негативну умову: якщо умова не виконується, наслідок теж заперечний — «won't be».\n«Unless you hurry» = «if you don't hurry», тому наслідок у головному реченні буде заперечним «won't be on time».",
            "created_at": "2026-04-23T11:45:08.000000Z",
            "updated_at": "2026-04-23T11:45:08.000000Z"
        }
    ],
