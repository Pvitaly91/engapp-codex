            "id": 1,
            "uuid": "1-by-the-time-he-was-25-he-a1-a-mill",
            "question": "By the time he was 25, he {a1} a million pounds.",
            "source": "custom_past_time_clauses_mixed_test",
            "level": "B1",
            "answers": {
                "a1": "had made"
            },
            "options": [
                "made",
                "had made",
                "was making",
                "has made"
            ],
            "variants": [
                "By the time he was 25, he _____ a million pounds."
            ],
            "tag_keys": [
                "past_perfect",
                "time_clauses"
            ],
            "localizations": {
                "uk": {
                    "hint_provider": "chatgpt",
                    "hints": [
                        "{a1} Час: Past Perfect.  \nФормула: **had + V3**.  \nПриклад: *By the time she was 18, she had finished school.*"
                    ],
                    "explanations": {
                        "a1": {
                            "made": "❌ Past Simple (V2). Використовується для події у минулому, але тут важлива дія, що завершилась до цього віку.",
                            "was making": "❌ Past Continuous = was/were + V-ing. Показує процес, а не завершений факт.",
                            "has made": "❌ Present Perfect. Ми говоримо про минуле, тому ця форма неправильна.",
                            "had made": "✅ Past Perfect = had + V3. Правильно, бо дія завершилася до конкретного моменту у минулому (25 років)."
                        }
                    }
                }
            }
        },
