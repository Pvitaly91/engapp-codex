  "seeder_requirements": {
    "php_namespace": "Database\\Seeders\\V3\\TheoryLinks",
    "json_loader": "Use the same JSON-loader approach for all four new theory-link seeders.",
    "resolver_rules": [
      "Resolve text blocks by seeder_class + sort_order.",
      "Normalize tag names: lowercase, trim, replace spaces/hyphens/underscores consistently.",
      "If more than one tag maps to a bundle, merge all bundles preserving manifest order and dedupe text_block_uuid values.",
      "If a text block is missing, fail with a clear RuntimeException that says which page seeder/sort_order is missing.",
      "If a question is missing, warn and continue.",
      "Do not create or modify questions, answers, options, saved tests, pages, or text blocks. Only write question_theory_text_blocks and questions.theory_text_block_uuid."
    ],
    "notes": [
      "This page focuses on SVO and simple sentence structure. If a source question tag points to passive/inversion, use the closest local blocks unless Codex decides to add cross-page links explicitly."
    ]
  },
